# Copy this file to ".env" (same folder as manage.py) and fill in your real values.
# Django reads this automatically via python-dotenv (see isl_web/settings.py).

DEBUG=True
SECRET_KEY=replace-this-with-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Required: point this at the folder that directly contains word/ and sentence/ ──
# This is the same folder predict.py lives in. Example (Windows):
# ISL_ROOT=C:\Users\YourName\Downloads\ISL_project\ISL_project
ISL_ROOT=

# ── Optional: only set these if your .keras/.json files are NOT inside      ──
# ── isl_web/word/ and isl_web/sentence/. Use absolute paths if you set them. ──
ISL_WORD_MODEL_PATH=
ISL_LABEL_MAP_PATH=
ISL_SENTENCE_MODEL_PATH=
ISL_SENTENCE_LABEL_PATH=
